{
	"name": "upwork-ai-chatbot",
	"version": "1.0.1",
	"private": true,
	"engines": {
		"npm": ">=10.0.0 <11"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "rollup -c rollup.config.mjs && next build",
		"build:widget": "rollup -c rollup.config.mjs",
		"start": "next start",
		"check": "biome check --write .",
		"lint": "biome lint --write .",
		"format": "biome format --write .",
		"seed": "npx tsx --env-file=.env.local scripts/seed.ts",
		"seed:analytics": "npx tsx --env-file=.env.local scripts/seed-analytics.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.28",
		"@ai-sdk/react": "^3.0.87",
		"@neondatabase/serverless": "^1.0.2",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.36.2",
		"ai": "^6.0.85",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"gpt-tokenizer": "^3.4.0",
		"iron-session": "^8.0.4",
		"lucide-react": "^0.577.0",
		"motion": "^12.34.0",
		"next": "^15.3.2",
		"next-themes": "^0.4.6",
		"openai": "^5.1.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-dropzone": "^14.4.0",
		"recharts": "^3.7.0",
		"resend": "^6.9.2",
		"tailwind-merge": "^3.3.0"
	},
	"overrides": {
		"serialize-javascript": "^7.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@tailwindcss/postcss": "^4.1.4",
		"@types/node": "^22.15.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.1.2",
		"rollup": "^4.59.0",
		"tailwindcss": "^4.1.4",
		"tsx": "^4.19.2",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	}
}
