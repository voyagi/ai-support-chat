# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Admin
ADMIN_PASSWORD=your-admin-password
SESSION_SECRET=your-32-char-secret-minimum-length-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sandbox mode (allows prospects to upload their own docs)
NEXT_PUBLIC_SANDBOX_ENABLED=false

# Vercel Cron secret (for daily sandbox cleanup)
CRON_SECRET=

# Email alerts (Resend)
RESEND_API_KEY=
ALERT_EMAIL_FROM=noreply@yourdomain.com
COST_ALERT_EMAIL=your-email@example.com
